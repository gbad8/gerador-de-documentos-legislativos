@model Gdl.Web.Modules.Identity.Models.PerfilViewModel
@using Gdl.Web.Modules.Identity.Models.Enums

@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @ViewBag.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card-painel mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: var(--gdl-green) !important;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-user">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </div>
                        <div>
                            <h2 class="h4 mb-0 fw-bold text-gdl-blue">Meu Perfil</h2>
                            <p class="text-muted small mb-0">Atualize suas informações de acesso e exibição.</p>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Perfil" method="post">
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="mb-3 text-secondary border-bottom pb-2">Dados de Acesso</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Username" class="form-label fw-medium"></label>
                                <input asp-for="Username" class="form-control" />
                                <span asp-validation-for="Username" class="text-danger d-block mt-1"></span>
                                <div class="form-text">Usado para efetuar login no sistema. Não pode conter espaços.</div>
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-medium"></label>
                                <input asp-for="Email" type="email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger d-block mt-1"></span>
                            </div>
                        </div>

                        <h5 class="mb-3 text-secondary border-bottom pb-2">Informações Profissionais</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Nome" class="form-label fw-medium"></label>
                                <input asp-for="Nome" class="form-control" />
                                <span asp-validation-for="Nome" class="text-danger d-block mt-1"></span>
                                <div class="form-text">Como seu nome aparecerá em relatórios e ofícios.</div>
                            </div>
                            <div class="col-12">
                                <label asp-for="Cargo" class="form-label fw-medium"></label>
                                <select asp-for="Cargo" asp-items="Html.GetEnumSelectList<CargoUsuario>()" class="form-select"></select>
                                <span asp-validation-for="Cargo" class="text-danger d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 border">Voltar</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Salvar Alterações</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
