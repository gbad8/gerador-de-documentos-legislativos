@{
    Layout = null;
    ViewData["Title"] = "Gerador de Documentos Legislativos";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/gdl.css" asp-append-version="true">
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="~/images/favicon-96x96.png" sizes="96x96">
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg">
    <link rel="shortcut icon" href="~/images/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png">

    <style>
        .hero-section {
            background-color: var(--gdl-blue);
            color: white;
            padding: 80px 0 100px;
            position: relative;
            overflow: hidden;
        }
        .hero-section::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: 0;
            width: 100%;
            height: 100px;
            background: #F8FAFC;
            transform: skewY(-2deg);
            z-index: 1;
        }
        .hero-content {
            position: relative;
            z-index: 2;
        }
        .feature-icon {
            width: 60px;
            height: 60px;
            background-color: rgba(3, 239, 98, 0.1);
            color: var(--gdl-green);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }
        .btn-custom-cta {
            background-color: var(--gdl-green);
            color: var(--gdl-blue);
            font-weight: 700;
            padding: 12px 30px;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }
        .btn-custom-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(3, 239, 98, 0.3);
            color: var(--gdl-blue);
        }
        .navbar-public {
            background-color: var(--gdl-blue);
            padding: 15px 0;
        }
    </style>
</head>
<body class="bg-light">

    <!-- Public Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-public">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <img src="~/images/logo_gdl.png" alt="GDL" height="30" class="me-2" style="filter: brightness(0) invert(1);">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navPublic">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navPublic">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#funcionalidades">Funcionalidades</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="#adesao">Solicitar Acesso</a>
                    </li>
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                        <a class="btn btn-outline-light rounded-pill px-4" asp-controller="Account" asp-action="Login">Entrar</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container hero-content">
            <div class="row align-items-center">
                <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0">
                    <h1 class="display-4 fw-bold mb-4">Padronize os documentos da sua Câmara Municipal.</h1>
                    <p class="lead opacity-75 mb-5">O GDL é um software público e gratuito criado para acabar com a bagunça de arquivos Word. Numeração automática, formatação oficial em PDF e organização por gabinetes.</p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                        <a href="#adesao" class="btn-custom-cta">Quero usar na minha Câmara</a>
                        <a href="#funcionalidades" class="btn btn-outline-light rounded-pill px-4 py-2 border-2">Conhecer mais</a>
                    </div>
                </div>
                <div class="col-lg-5 offset-lg-1 text-center">
                    <!-- Dashboard Preview Graphic -->
                    <div class="card-painel p-3 bg-white text-start shadow-lg" style="border-radius: 12px; transform: rotate(2deg);">
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                            <div class="fw-bold text-gdl-blue">Últimos Ofícios</div>
                            <span class="badge bg-primary text-dark" style="background-color: var(--gdl-green) !important;">Oficial</span>
                        </div>
                        <div class="p-2 mb-2 rounded" style="background: #f8f9fa;">Ofício n° 045/2026 - Instalação de Lixeiras</div>
                        <div class="p-2 mb-2 rounded" style="background: #f8f9fa;">Ofício n° 046/2026 - Reparo asfáltico na Av. Brasil</div>
                        <div class="p-2 rounded opacity-50" style="background: #f8f9fa;">Ofício n° 047/2026 - Rascunho...</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mt-4">
            <div class="alert alert-success alert-dismissible fade show text-center fw-bold" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="container mt-4">
            <div class="alert alert-danger alert-dismissible fade show text-center fw-bold" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <!-- Features -->
    <section id="funcionalidades" class="py-5" style="background-color: #F8FAFC;">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold text-gdl-blue">Feito para o Legislativo</h2>
                <p class="text-muted">Desenhado especificamente para a burocracia das Câmaras Municipais.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card-painel h-100 p-4 border-0 shadow-sm hover-lift">
                        <div class="feature-icon">
                            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" class="feather feather-file-text"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        </div>
                        <h4 class="h5 fw-bold text-gdl-blue">Padrão Visual Automático</h4>
                        <p class="text-muted mb-0">Escreva o texto do ofício num editor simples e o sistema gera um PDF pronto para assinar, com timbre, cabeçalho e rodapé oficiais.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-painel h-100 p-4 border-0 shadow-sm hover-lift">
                        <div class="feature-icon">
                            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" class="feather feather-hash"><line x1="4" y1="9" x2="20" y2="9"></line><line x1="4" y1="15" x2="20" y2="15"></line><line x1="10" y1="3" x2="8" y2="21"></line><line x1="16" y1="3" x2="14" y2="21"></line></svg>
                        </div>
                        <h4 class="h5 fw-bold text-gdl-blue">Numeração Inteligente</h4>
                        <p class="text-muted mb-0">Chega de perguntar "Qual é o próximo número de ofício?". O GDL controla a numeração de ofícios de forma isolada para cada Vereador e Órgão.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-painel h-100 p-4 border-0 shadow-sm hover-lift">
                        <div class="feature-icon">
                            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" class="feather feather-users"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        </div>
                        <h4 class="h5 fw-bold text-gdl-blue">Multigabinete</h4>
                        <p class="text-muted mb-0">Vários assessores podem trabalhar juntos na mesma Câmara, com áreas separadas para os documentos da Presidência, Secretaria e Gabinetes.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Formulário Adesão CTA -->
    <section id="adesao" class="py-5 bg-white">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-lg-5 mb-4 mb-lg-0">
                    <h2 class="fw-bold text-gdl-blue mb-4">Gratuito e Código Aberto</h2>
                    <p class="lead opacity-75 mb-4">Sua Câmara não paga licenças milionárias. O GDL é um software cedido para adoção governamental.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex align-items-center mb-3">
                            <svg width="20" height="20" fill="none" stroke="var(--gdl-green)" stroke-width="3" class="me-3 feather feather-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Servidor isolado por Câmara
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <svg width="20" height="20" fill="none" stroke="var(--gdl-green)" stroke-width="3" class="me-3 feather feather-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Exportação em lote
                        </li>
                        <li class="d-flex align-items-center">
                            <svg width="20" height="20" fill="none" stroke="var(--gdl-green)" stroke-width="3" class="me-3 feather feather-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Atualizações constantes
                        </li>
                    </ul>
                </div>
                <div class="col-lg-6 offset-lg-1">
                    <div class="card-painel p-5 shadow-lg border-0">
                        <h4 class="mb-4 text-gdl-blue fw-bold">Solicitar Abertura de Ambiente</h4>
                        <!-- O form chamará Action CriarSolicitacao no HomeController futuramente -->
                        <form asp-controller="Home" asp-action="SolicitarAcesso" method="post">
                            <div class="mb-3">
                                <label class="form-label fw-medium text-secondary">Câmera Municipal (Ex: Câmara M. de Piracicaba)</label>
                                <input type="text" name="NomeCamara" class="form-control" required placeholder="Nome do Órgão Legislativo">
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-medium text-secondary">Estado (UF)</label>
                                    <input type="text" name="Estado" class="form-control" placeholder="SP" maxlength="2" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium text-secondary">Telefone de Contato</label>
                                    <input type="text" name="Telefone" class="form-control" placeholder="(00) 0000-0000" required>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-medium text-secondary">E-mail do Responsável de TI ou Administração</label>
                                <input type="email" name="Email" class="form-control" required placeholder="admin@camara.leg.br">
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.5px;">Enviar Solicitação</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gdl-blue text-white py-4 border-top border-secondary">
        <div class="container text-center">
            <img src="~/images/logo_gdl.png" alt="Logo GDL" style="height: 30px; filter: brightness(0) invert(1);" class="mb-3">
            <p class="text-white-50 small mb-0">&copy; @DateTime.Now.Year GDL - Gerador de Documentos Legislativos.</p>
            <p class="text-white-50 small">Desenvolvido com foco no serviço público.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
