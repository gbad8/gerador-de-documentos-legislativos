@model IEnumerable<Gdl.Web.Modules.Oficios.Models.Oficio>
@using Gdl.Web.Modules.Oficios.Models.Enums
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@functions {
    public static string GetEnumDisplayName(Enum enumValue)
    {
        return enumValue.GetType()
            .GetMember(enumValue.ToString())
            .First()
            .GetCustomAttribute<DisplayAttribute>()
            ?.Name ?? enumValue.ToString();
    }
}

@if (Model.Any())
{
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light text-secondary">
            <tr>
                <th>Número</th>
                <th>Assunto</th>
                <th>Órgão</th>
                <th>Autor</th>
                <th>Data</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var oficio in Model)
            {
                <tr class="clickable-row" data-href="@Url.Action("Preview", new { id = oficio.Id })">
                    <td><span class="fw-medium text-gdl-blue">@oficio.Numero</span></td>
                    <td>@oficio.Assunto</td>
                    <td>@(oficio.Orgao?.Abreviatura ?? "-")</td>
                    <td>@oficio.Autor?.Nome</td>
                    <td class="text-nowrap">@oficio.Data.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge @(oficio.Status == StatusOficio.Finalizado ? "bg-success bg-opacity-10 text-success" : oficio.Status == StatusOficio.Modificado ? "bg-warning bg-opacity-10 text-warning" : "bg-secondary bg-opacity-10 text-secondary") rounded-pill px-3 py-2">
                            @GetEnumDisplayName(oficio.Status)
                        </span>
                    </td>
                    <td class="text-end">
                        <a href="@Url.Action("Edit", new { id = oficio.Id })" class="btn btn-sm btn-outline-primary rounded-pill px-3">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Nenhum ofício encontrado.</p>
}
