@model Gdl.Web.Modules.Oficios.Models.Oficio
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <title>Ofício @Model.Numero - Ver. @Model.Autor?.Nome</title>
    <style>
        @@page {
            size: A4;
            margin: 4.5cm 2.5cm 3cm;
        }
        body {
            font-family: "Times New Roman", Times, serif;
            font-size: 12pt;
            line-height: 1.3;
            color: #000;
        }
        .header {
            position: fixed;
            top: -3.5cm;
            left: 0;
            right: 0;
            text-align: center;
            border-bottom: 1px solid #000;
            padding-bottom: 0.8cm;
            height: 3cm;
        }
        .header h2 {
            font-size: 10pt;
            margin: 0;
            text-transform: uppercase;
        }
        .header p {
            font-size: 10pt;
            margin: 0;
            color: #555;
        }
        .oficio-numero {
            text-align: left;
            margin-bottom: 0.5cm;
        }
        .oficio-orgao {
            text-align: right;
            margin-bottom: 0.5cm;
            margin-top: 0.5cm;
        }
        .data-assinatura {
            text-align: right;
            margin-bottom: 1cm;
            font-family: "Times New Roman", Times, serif;
            font-size: 12pt;
        }
        .destinatario {
            margin-bottom: 1cm;
            line-height: 1.15;
        }
        .corpo {
            text-align: justify;
            margin-bottom: 1cm;
        }
        .corpo p {
            text-align: justify;
        }
        .assinatura {
            text-align: center;
            padding-top: 3cm;
        }
        .assinatura-primeira {
            text-align: center;
            padding-top: 2cm;
        }
        .assinatura-linha {
            border-top: 1px solid #000;
            width: 7cm;
            margin: 0 auto 0.1cm auto;
        }
        .footer {
            position: fixed;
            bottom: -2.3cm;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 8pt;
            color: #000;
            border-top: 1px solid #000;
            padding-top: 0.3cm;
        }
    </style>
</head>
<body>
    <div class="header">
        @if (!string.IsNullOrEmpty(Model.Camara?.LogomarcaBase64))
        {
            <img src="data:image/png;base64,@Model.Camara.LogomarcaBase64" style="max-height: 70px; margin-bottom: 10px;" />
        }
        <h2>Estado de @Model.Camara?.Estado</h2>
        <h2> PODER LEGISLATIVO</h2>
        <h2>@Model.Camara?.Nome</h2>
    </div>

    @if (Model.Orgao != null)
    {
        <div class="oficio-orgao">
            <strong>@Model.Orgao.Nome</strong>
        </div>
    }

    <div class="oficio-numero">
        <strong>Ofício nº @Model.Numero</strong>
    </div>

    <div class="data-assinatura">
        @(string.IsNullOrEmpty(Model.Camara?.Cidade) ? Model.Camara?.Endereco : Model.Camara?.Cidade), @Model.Data.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR")).
    </div>

    <div class="destinatario">
        <p>
            @Model.DestinatarioPronome<br>
            <strong>@Model.DestinatarioNome</strong><br>
            <i>
                @if (!string.IsNullOrEmpty(Model.DestinatarioCargo)) { <text>@Model.DestinatarioCargo<br></text> }
                @if (!string.IsNullOrEmpty(Model.DestinatarioOrgao)) { <text>@Model.DestinatarioOrgao<br></text> }
                @if (!string.IsNullOrEmpty(Model.DestinatarioEndereco)) { <text>@Model.DestinatarioEndereco</text> }
            </i>
        </p>
    </div>

    <p><strong>ASSUNTO: @Model.Assunto.ToUpper()</strong></p>

    <div class="corpo">
        @Html.Raw(Model.Corpo.Replace("\n", "<br/>"))
    </div>

    <div class="fechamento" style="page-break-inside: avoid;">
        <p>Atenciosamente,</p>

        <div class="assinatura-primeira" style="page-break-inside: avoid;">
            <div class="assinatura-linha"></div>
            <strong>@Model.Autor?.Nome</strong><br>
            <i>@Model.Autor?.Cargo.ToString()</i>
        </div>
    </div>
    
    @foreach(var coautor in Model.Coautores)
    {
        <div class="assinatura" style="page-break-inside: avoid;">
            <div class="assinatura-linha"></div>
            <strong>@coautor.Nome</strong><br>
            <i>@coautor.Cargo.ToString()</i>
        </div>
    }

    <div class="footer">
        @Model.Camara?.Nome @if(!string.IsNullOrEmpty(Model.Camara?.Cnpj)) { <text>— CNPJ: @Model.Camara.Cnpj</text> }<br>
        @(Model.Camara?.Endereco ?? "") @if(!string.IsNullOrEmpty(Model.Camara?.Cep)) { <text>— CEP: @Model.Camara.Cep</text> }
        @if(!string.IsNullOrEmpty(Model.Camara?.Telefone)) { <text>— Tel: @Model.Camara.Telefone</text> }
        @if(!string.IsNullOrEmpty(Model.Camara?.Email)) { <text>— E-mail: @Model.Camara.Email</text> }
    </div>
</body>
</html>
