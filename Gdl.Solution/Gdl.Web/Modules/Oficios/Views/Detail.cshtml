@model Gdl.Web.Modules.Oficios.Models.Oficio
@{
    ViewData["Title"] = "Pré-visualizar Ofício";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-gdl-blue">Pré-visualização</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary rounded-pill px-4 me-2">Editar</a>
            <a href="@Url.Action("GeneratePdf", new { id = Model.Id })" target="_blank" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-pdf-fill me-1" viewBox="0 0 16 16">
                  <path d="M5.523 12.424c.14-.082.293-.162.459-.238a7.878 7.878 0 0 1-.45.606c-.28.337-.498.516-.635.572a.266.266 0 0 1-.035.012.282.282 0 0 1-.026-.044c-.056-.11-.054-.216.04-.36.106-.165.319-.354.647-.548zm2.455-1.647c-.119.025-.237.05-.356.078a21.148 21.148 0 0 0 .5-1.05 12.045 12.045 0 0 0 .51.858c-.217.032-.436.07-.654.114zm2.525.939a3.881 3.881 0 0 1-.435-.41c.228.005.434.022.612.054.317.057.466.147.518.209a.095.095 0 0 1 .026.064.436.436 0 0 1-.06.2.307.307 0 0 1-.094.124.107.107 0 0 1-.069.015c-.09-.003-.258-.066-.498-.256zM8.278 6.97c-.04.244-.108.524-.2.829a4.86 4.86 0 0 1-.089-.346c-.076-.353-.087-.73-.04-.96.04-.207.143-.326.287-.326.096 0 .151.045.182.137a1.15 1.15 0 0 1-.029.2v.001c-.01.054-.035.127-.081.258l-.03.076zm4.61 7.425a.86.86 0 0 0-.063-.092c-.11-.144-.337-.253-.589-.352-.16-.062-.352-.108-.57-.145a11.13 11.13 0 0 0-1.85-.098 12.19 12.19 0 0 0-1.127-.67c-.201-.098-.445-.2-.734-.298-.242-.239-.533-.49-.854-.741a14.54 14.54 0 0 0 .445-1.687c.05-.286.082-.57.095-.845-.045-.23-.1-.453-.16-.671A2.5 2.5 0 0 0 6.643 4H5.5c-1.38 0-2.5 1.12-2.5 2.5v9h10V14.395z"/>
                </svg>
                Gerar PDF
            </a>
        </div>
    </div>

    @await Html.PartialAsync("_Preview", Model)

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Voltar para Ofícios</a>
    </div>
</div>
