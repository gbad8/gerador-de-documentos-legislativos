@model Gdl.Web.Modules.Oficios.Models.Oficio
@using Gdl.Web.Modules.Oficios.Models.Enums
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@functions {
    public static string GetEnumDisplayName(Enum enumValue)
    {
        return enumValue.GetType()
            .GetMember(enumValue.ToString())
            .First()
            .GetCustomAttribute<DisplayAttribute>()
            ?.Name ?? enumValue.ToString();
    }
}

<div class="card-painel mb-4">
    <div class="card-body p-4 p-md-5">
        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Número:</strong> @Model.Numero
            </div>
            <div class="col-md-6">
                <strong>Data:</strong> @Model.Data.ToString("dd/MM/yyyy")
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Autor Principal:</strong> @Model.Autor?.Nome
                @if (Model.EConjunto && Model.Coautores.Any())
                {
                    <br><strong>Coautores:</strong> 
                    @string.Join(", ", Model.Coautores.Select(c => c.Nome))
                }
            </div>
            <div class="col-md-6">
                <strong class="text-gdl-blue">Status:</strong>
                <span class="badge @(Model.Status == StatusOficio.Finalizado ? "bg-success bg-opacity-10 text-success" : Model.Status == StatusOficio.Modificado ? "bg-warning bg-opacity-10 text-warning" : "bg-secondary bg-opacity-10 text-secondary") rounded-pill px-3 py-2 ms-2">
                    @GetEnumDisplayName(Model.Status)
                </span>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-12">
                <strong>Órgão Emissor:</strong> @(Model.Orgao?.Nome ?? "-")
            </div>
        </div>

        <hr>

        <div class="row mb-3">
            <div class="col">
                <strong>Assunto:</strong> @Model.Assunto
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <strong>Destinatário:</strong> @Model.DestinatarioNome
            </div>
            <div class="col-md-4">
                <strong>Cargo:</strong> @(Model.DestinatarioCargo ?? "-")
            </div>
            <div class="col-md-4">
                <strong>Órgão:</strong> @(Model.DestinatarioOrgao ?? "-")
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.DestinatarioEndereco))
        {
            <div class="row mb-3">
                <div class="col">
                    <strong>Endereço:</strong> @Model.DestinatarioEndereco
                </div>
            </div>
        }

        <hr>

        <div class="mb-3">
            <strong>Corpo do Ofício:</strong>
            <div class="mt-2 p-3 bg-light border rounded" style="text-align: justify;">
                @Html.Raw(Model.Corpo.Replace("\n", "<br/>"))
            </div>
        </div>
    </div>
</div>
