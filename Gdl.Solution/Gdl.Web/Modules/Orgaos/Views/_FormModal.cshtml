@model Gdl.Web.Modules.Orgaos.Models.OrgaoViewModel

<form hx-post="@Url.Action(Model.Id == 0 ? "Create" : "Edit")" hx-target="#modalDialogContent" method="post" autocomplete="off">
    <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-gdl-blue">@(Model.Id == 0 ? "Novo Órgão Interno" : "Editar Órgão")</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body py-4">
        <input type="hidden" asp-for="Id" />
        
        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-medium"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-2">
            <label asp-for="Abreviatura" class="form-label fw-medium"></label>
            <input asp-for="Abreviatura" class="form-control" />
            <span asp-validation-for="Abreviatura" class="text-danger small mt-1 d-block"></span>
            <div class="form-text">Usada para compor a numeração do ofício (Ex: DEM, PRES).</div>
        </div>
    </div>
    <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Salvar Alterações</button>
    </div>
</form>
