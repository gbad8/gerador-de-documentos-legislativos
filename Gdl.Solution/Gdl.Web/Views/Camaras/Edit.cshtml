@model Gdl.Web.Modules.Camaras.Models.CamaraViewModel
@{
    ViewData["Title"] = "Editar Casa Legislativa";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Camaras" asp-action="Index">Configurações</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Casa Legislativa</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-1 text-gdl-blue">Casa Legislativa</h2>
            <p class="text-muted">Utilize o formulário abaixo para atualizar os dados da sua instituição.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card-painel p-4 mb-4">
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Nome" class="form-label"></label>
                                <input asp-for="Nome" class="form-control" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Cidade" class="form-label"></label>
                                <input asp-for="Cidade" class="form-control" />
                                <span asp-validation-for="Cidade" class="text-danger small"></span>
                            </div>
                            <div class="col-md-2">
                                <label asp-for="Estado" class="form-label"></label>
                                <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<Gdl.Web.Modules.Camaras.Models.Enums.EstadoCamara>()"></select>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Cnpj" class="form-label"></label>
                                <input asp-for="Cnpj" class="form-control" />
                                <span asp-validation-for="Cnpj" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Telefone" class="form-label"></label>
                                <input asp-for="Telefone" class="form-control" />
                                <span asp-validation-for="Telefone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" type="email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Cep" class="form-label"></label>
                                <input asp-for="Cep" class="form-control" />
                                <span asp-validation-for="Cep" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="Endereco" class="form-label"></label>
                                <input asp-for="Endereco" class="form-control" />
                                <span asp-validation-for="Endereco" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <h5 class="mb-3">Logotipo</h5>
                        <div class="row mb-4 align-items-center">
                            <div class="col-md-4 text-center">
                                @if (!string.IsNullOrEmpty(Model.LogomarcaBase64))
                                {
                                    <img src="data:image/png;base64,@(Model.LogomarcaBase64)" class="img-thumbnail w-100" style="max-width: 150px" alt="Logotipo Atual">
                                    <div class="small text-muted mt-2">Logotipo Atual</div>
                                }
                                else
                                {
                                    <div class="bg-body-secondary border rounded d-flex align-items-center justify-content-center mx-auto" style="width: 150px; height: 150px;">
                                        <span class="text-muted small">Sem imagem</span>
                                    </div>
                                }
                            </div>
                            <div class="col-md-8">
                                <label asp-for="UploadLogomarca" class="form-label"></label>
                                <input asp-for="UploadLogomarca" class="form-control" type="file" accept="image/png, image/jpeg, image/gif" />
                                <span asp-validation-for="UploadLogomarca" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-controller="Camaras" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Salvar Alterações</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const cepInput = document.getElementById("@Html.IdFor(m => m.Cep)");
            
            if (cepInput) {
                cepInput.setAttribute("maxlength", "9");

                cepInput.addEventListener("input", function (e) {
                    let value = e.target.value.replace(/\D/g, "");
                    if (value.length > 5) {
                        value = value.replace(/^(\d{5})(\d{1,3}).*/, "$1-$2");
                    }
                    e.target.value = value;
                });
            }
        });
    </script>
}
