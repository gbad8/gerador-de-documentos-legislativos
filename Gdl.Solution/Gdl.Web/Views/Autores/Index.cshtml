@{
    ViewData["Title"] = "Autores";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold text-gdl-blue">Autores (Vereadores)</h2>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm"
                hx-get="@Url.Action("Create")"
                hx-target="#modalDialogContent"
                data-bs-toggle="modal"
                data-bs-target="#modalContainer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
            </svg>
            Novo Autor
        </button>
    </div>

    <!-- Container da Tabela Recarregável -->
    <div id="autorListContainer" hx-get="@Url.Action("List")" hx-trigger="load, autoresChanged from:body">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Camaras" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-1" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
            </svg>
            Voltar para Configurações
        </a>
    </div>
</div>

<!-- Modal Compartilhado -->
<div class="modal fade" id="modalContainer" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="modalDialogContent">
            <!-- HTMX injects forms here -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.body.addEventListener('autoresChanged', function () {
            var modalEl = document.getElementById('modalContainer');
            var modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) {
                modal.hide();
            }
        });

        // Limpar o cache do modal ao fechar para evitar flicker
        document.getElementById('modalContainer').addEventListener("hidden.bs.modal", function () {
            document.getElementById('modalDialogContent').innerHTML = "";
        });
    </script>
}
