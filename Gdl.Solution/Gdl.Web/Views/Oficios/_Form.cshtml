@model Gdl.Web.Modules.Oficios.Models.OficioViewModel

<div class="row g-3 align-items-center mb-3">
    @if (!string.IsNullOrEmpty(Model.Numero))
    {
        <div class="col-auto">
            <label class="col-form-label fw-medium">Número do Ofício:</label>
        </div>
        <div class="col-auto">
            <input type="text" class="form-control bg-light" value="@Model.Numero" disabled>
        </div>
    }
    <div class="col-auto">
        <label asp-for="Data" class="col-form-label fw-medium"></label>
    </div>
    <div class="col-auto">
        <input asp-for="Data" class="form-control" />
    </div>
    <span asp-validation-for="Data" class="text-danger small col-12"></span>
</div>

<div class="mb-3">
    <label asp-for="Assunto" class="form-label fw-medium"></label>
    <input asp-for="Assunto" class="form-control" />
    <span asp-validation-for="Assunto" class="text-danger small"></span>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <label asp-for="OrgaoId" class="form-label fw-medium"></label>
        <select asp-for="OrgaoId" class="form-select">
            <option value="">-- Selecione (Opcional) --</option>
            @foreach (var orgao in ViewBag.Orgaos)
            {
                <option value="@orgao.Id">@orgao.Nome</option>
            }
        </select>
        <span asp-validation-for="OrgaoId" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="AutorId" class="form-label fw-medium"></label>
        <select asp-for="AutorId" class="form-select">
            <option value="">-- Selecione o Autor --</option>
            @foreach (var autor in ViewBag.Autores)
            {
                <option value="@autor.Id">@autor.Nome</option>
            }
        </select>
        <span asp-validation-for="AutorId" class="text-danger small"></span>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <div class="form-check form-switch">
            <input asp-for="EConjunto" class="form-check-input" />
            <label asp-for="EConjunto" class="form-check-label fw-medium"></label>
        </div>
    </div>
</div>

<div id="coautores-container" class="mb-4" style="display: none;">
    <label asp-for="CoautoresIds" class="form-label fw-medium"></label>
    <select asp-for="CoautoresIds" class="form-select" multiple size="4">
        @foreach (var autor in ViewBag.Autores)
        {
            <option value="@autor.Id">@autor.Nome</option>
        }
    </select>
    <span asp-validation-for="CoautoresIds" class="text-danger small"></span>
    <div class="form-text">Segure Ctrl (ou Cmd no Mac) para selecionar múltiplos.</div>
</div>

<h5 class="fw-bold mt-4 mb-3 text-gdl-blue">Destinatário</h5>
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <label asp-for="DestinatarioNome" class="form-label fw-medium"></label>
        <input asp-for="DestinatarioNome" class="form-control" />
        <span asp-validation-for="DestinatarioNome" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DestinatarioCargo" class="form-label fw-medium"></label>
        <input asp-for="DestinatarioCargo" class="form-control" />
        <span asp-validation-for="DestinatarioCargo" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DestinatarioPronome" class="form-label fw-medium"></label>
        <input asp-for="DestinatarioPronome" class="form-control" />
        <span asp-validation-for="DestinatarioPronome" class="text-danger small"></span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <label asp-for="DestinatarioOrgao" class="form-label fw-medium"></label>
        <input asp-for="DestinatarioOrgao" class="form-control" />
        <span asp-validation-for="DestinatarioOrgao" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DestinatarioEndereco" class="form-label fw-medium"></label>
        <input asp-for="DestinatarioEndereco" class="form-control" />
        <span asp-validation-for="DestinatarioEndereco" class="text-danger small"></span>
    </div>
</div>

<div class="mb-3 mt-4">
    <label asp-for="Corpo" class="form-label fw-medium"></label>
    <textarea asp-for="Corpo" class="form-control tinymce-editor"></textarea>
    <span asp-validation-for="Corpo" class="text-danger small"></span>
</div>
