@model Gdl.Web.Modules.Oficios.Models.OficioViewModel
@{
    ViewData["Title"] = "Editar Ofício";
}
<div class="container py-5">
    <div class="card-painel p-4 p-md-5 mb-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <h3 class="fw-bold mb-4 text-gdl-blue">Editar Ofício</h3>
            <partial name="_Form" model="Model" />
            <div class="col-12 mt-4">
                <button class="btn btn-primary rounded-pill px-4 shadow-sm" type="submit">Salvar Alterações</button>
                <a asp-action="Preview" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            tinymce.init({
                selector: '.tinymce-editor',
                height: 400,
                menubar: false,
                plugins: 'lists link table paste wordcount',
                toolbar: 'undo redo | formatselect | bold italic underline | alignleft aligncenter alignright | bullist numlist outdent indent | removeformat',
                language: 'pt_BR'
            });

            const switchConjunto = document.getElementById('@Html.IdFor(m => m.EConjunto)');
            const containerCoautores = document.getElementById('coautores-container');

            function toggleCoautores() {
                if (switchConjunto.checked) {
                    containerCoautores.style.display = 'block';
                } else {
                    containerCoautores.style.display = 'none';
                }
            }

            if (switchConjunto && containerCoautores) {
                switchConjunto.addEventListener('change', toggleCoautores);
                toggleCoautores();
            }
        });
    </script>
}
